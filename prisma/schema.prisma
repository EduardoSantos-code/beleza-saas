generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                            String                     @id @default(cuid())
  name                          String
  slug                          String                     @unique
  timezone                      String                     @default("America/Sao_Paulo")
  createdAt                     DateTime                   @default(now())
  address                       String?
  heroImageUrl                  String?
  instagram                     String?
  logoUrl                       String?
  primaryColor                  String?                    @default("#7c3aed")
  publicDescription             String?
  publicPhone                   String?
  cpfCnpj                       String?
  asaasCustomerId               String?                    @unique
  asaasSubscriptionId           String?                    @unique
  planStatus                    String                     @default("TRIAL") // TRIAL, ACTIVE, OVERDUE
  planTier                      String                     @default("PRO") // BASICO, ESSENCIAL, PRO
  planCycle                     String                     @default("MONTHLY") // MONTHLY, YEARLY
  subscriptionCancelAtPeriodEnd Boolean                    @default(false)
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionStatus            TenantSubscriptionStatus   @default(NONE)
  trialEndsAt                   DateTime?
  minAdvanceHours               Int                        @default(2)
  clubEnabled                   Boolean                    @default(false)
  clubPaymentProvider           ClubPaymentProvider?
  clubAsaasApiKeyEnc            String?
  clubAsaasEnvironment          ClubAsaasEnvironment       @default(SANDBOX)
  clubMercadoPagoAccessTokenEnc String?
  clubMercadoPagoPublicKey      String?
  clubMercadoPagoEnvironment    ClubMercadoPagoEnvironment @default(SANDBOX)
  clubPlans                     ClubPlan[]
  clubSubscriptions             ClubSubscription[]
  clubBenefitUsages             ClubBenefitUsage[]
  clubBillingWebhookEvents      ClubBillingWebhookEvent[]
  appointments                  Appointment[]
  clients                       Client[]
  memberships                   Membership[]
  professionals                 Professional[]
  blocks                        ScheduleBlock[]
  services                      Service[]
  businessHours                 TenantBusinessHour[]
  clientPhoneVerifications      ClientPhoneVerification[]
  whatsappConfig                WhatsappConfig?
  products                      Product[]
  productReservations           ProductReservation[]
  reviews                       Review[]
  galleryPhotos                 GalleryPhoto[]
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  createdAt     DateTime       @default(now())
  role          String         @default("USER")
  memberships   Membership[]
  professionals Professional[]
}

model Membership {
  id       String         @id @default(cuid())
  userId   String
  tenantId String
  role     MembershipRole @default(STAFF)
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Professional {
  id             String                     @id @default(cuid())
  tenantId       String
  userId         String?
  name           String
  active         Boolean                    @default(true)
  commissionRate Int                        @default(50)
  imageUrl       String?
  createdAt      DateTime                   @default(now())
  phoneE164      String?
  updatedAt      DateTime                   @updatedAt
  appointments   Appointment[]
  tenant         Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user           User?                      @relation(fields: [userId], references: [id], onDelete: SetNull)
  businessHours  ProfessionalBusinessHour[]
  blocks         ScheduleBlock[]

  @@index([tenantId, active])
}

model Service {
  id                String             @id @default(cuid())
  tenantId          String
  name              String
  durationMin       Int
  active            Boolean            @default(true)
  price             Int                @default(0)
  appointments      Appointment[]
  clubPlansIncluded ClubPlan[]         @relation("ClubPlanIncludedService")
  clubBenefitUsages ClubBenefitUsage[]
  tenant            Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, active])
}

model Client {
  id                String                    @id @default(cuid())
  tenantId          String
  name              String
  phoneE164         String?
  email             String?
  createdAt         DateTime                  @default(now())
  noShowCount       Int                       @default(0)
  lateCancelCount   Int                       @default(0)
  completedCount    Int                       @default(0)
  appointments      Appointment[]
  clubSubscriptions ClubSubscription[]
  clubBenefitUsages ClubBenefitUsage[]
  tenant              Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productReservations ProductReservation[]
  reviews             Review[]

  @@unique([tenantId, phoneE164])
  @@index([tenantId])
}

model Appointment {
  id                 String             @id @default(cuid())
  tenantId           String
  professionalId     String
  serviceId          String
  clientId           String
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus  @default(PENDING)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  businessDate       String
  endMinutes         Int
  startMinutes       Int
  timeZone           String             @default("America/Sao_Paulo")
  reminderSent       Boolean            @default(false)
  presenceConfirmed  Boolean            @default(false)
  clubSubscriptionId String?
  clubPlanName       String?
  clubOriginalPrice  Int?
  clubDiscountAmount Int?
  clubFinalPrice     Int?
  client             Client             @relation(fields: [clientId], references: [id])
  professional       Professional       @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service            Service            @relation(fields: [serviceId], references: [id])
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reminder           Reminder?
  clubSubscription   ClubSubscription?  @relation(fields: [clubSubscriptionId], references: [id])
  clubBenefitUsages  ClubBenefitUsage[]
  review             Review?

  @@index([tenantId, professionalId, startAt])
  @@index([tenantId, status])
  @@index([tenantId, businessDate])
}

model Reminder {
  id            String         @id @default(cuid())
  appointmentId String         @unique
  sendAt        DateTime
  status        ReminderStatus @default(PENDING)
  attempts      Int            @default(0)
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status, sendAt])
}

model WhatsappConfig {
  id               String   @id @default(cuid())
  tenantId         String   @unique
  provider         String   @default("EVOLUTION")
  instanceName     String?  @unique
  instanceToken    String?
  status           String   @default("DISCONNECTED")
  connectedPhone   String?
  profileName      String?
  qrCodeBase64     String?
  qrCodeText       String?
  pairingCode      String?
  lastConnectionAt DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantBusinessHour {
  id            String   @id @default(cuid())
  tenantId      String
  weekday       Weekday
  isOpen        Boolean  @default(false)
  startMin      Int?
  endMin        Int?
  breakStartMin Int?
  breakEndMin   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, weekday])
  @@index([tenantId, weekday])
}

model ProfessionalBusinessHour {
  id             String       @id @default(cuid())
  professionalId String
  weekday        Weekday
  isOpen         Boolean      @default(false)
  startMin       Int?
  endMin         Int?
  breakStartMin  Int?
  breakEndMin    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, weekday])
  @@index([professionalId, weekday])
}

model ScheduleBlock {
  id             String        @id @default(cuid())
  tenantId       String
  professionalId String?
  title          String
  startAt        DateTime
  endAt          DateTime
  allDay         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startAt])
  @@index([professionalId, startAt])
}


model Announcement {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("INFO")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ClubPlan {
  id                    String             @id @default(cuid())
  tenantId              String
  name                  String
  description           String?
  terms                 String?
  priceInCents          Int
  billingCycle          ClubBillingCycle   @default(MONTHLY)
  discountPercent       Int?
  includedServices      Json?
  includedServiceId     String?
  includedUsesPerPeriod Int                @default(0)
  includedBenefitType   ClubBenefitType?
  isActive              Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  tenant                Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  includedService       Service?           @relation("ClubPlanIncludedService", fields: [includedServiceId], references: [id])
  subscriptions         ClubSubscription[]
  benefitUsages         ClubBenefitUsage[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model ClubSubscription {
  id                     String                    @id @default(cuid())
  tenantId               String
  clientId               String
  planId                 String
  provider               ClubPaymentProvider
  status                 ClubSubscriptionStatus    @default(PENDING)
  providerCustomerId     String?
  providerSubscriptionId String?
  providerPaymentId      String?
  providerCheckoutUrl    String?
  providerStatusRaw      String?
  providerReference      String?
  lastProviderSyncAt     DateTime?
  lastWebhookAt          DateTime?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime                  @default(now())
  updatedAt              DateTime                  @updatedAt
  tenant                 Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client                 Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan                   ClubPlan                  @relation(fields: [planId], references: [id])
  usages                 ClubBenefitUsage[]
  appointments           Appointment[]
  billingWebhookEvents   ClubBillingWebhookEvent[]

  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([provider, providerSubscriptionId])
  @@index([provider, providerReference])
}

model ClubBenefitUsage {
  id             String          @id @default(cuid())
  tenantId       String
  subscriptionId String
  appointmentId  String
  clientId       String
  planId         String
  serviceId      String
  periodKey      String
  benefitType    ClubBenefitType
  createdAt      DateTime        @default(now())

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  subscription ClubSubscription @relation(fields: [subscriptionId], references: [id])
  appointment  Appointment      @relation(fields: [appointmentId], references: [id])
  client       Client           @relation(fields: [clientId], references: [id])
  plan         ClubPlan         @relation(fields: [planId], references: [id])
  service      Service          @relation(fields: [serviceId], references: [id])

  @@index([tenantId, subscriptionId, periodKey])
  @@index([tenantId, clientId])
  @@index([appointmentId])
}

model ClubBillingWebhookEvent {
  id                String              @id @default(cuid())
  provider          ClubPaymentProvider
  externalEventId   String?
  topic             String?
  action            String?
  resourceId        String?
  providerReference String?
  tenantId          String?
  subscriptionId    String?
  payload           Json
  processed         Boolean             @default(false)
  processedAt       DateTime?
  error             String?
  createdAt         DateTime            @default(now())

  tenant       Tenant?           @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  subscription ClubSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@unique([provider, externalEventId])
  @@index([provider, createdAt])
  @@index([provider, resourceId])
  @@index([tenantId, createdAt])
  @@index([subscriptionId, createdAt])
}

model ClientPhoneVerification {
  id        String                         @id @default(cuid())
  tenantId  String
  phoneE164 String
  codeHash  String
  purpose   ClientPhoneVerificationPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                       @default(now())
  tenant    Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, phoneE164])
  @@index([tenantId, phoneE164, purpose])
}

enum ClubPaymentProvider {
  ASAAS
  MERCADO_PAGO
}

enum ClubBenefitType {
  FREE_SERVICE
}

enum ClubBillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum ClubSubscriptionStatus {
  PENDING
  ACTIVE
  OVERDUE
  CANCELED
  EXPIRED
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
  NOSHOW
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ClientPhoneVerificationPurpose {
  CLUB_SUBSCRIBE
  CLUB_PORTAL
  CLUB_USE_BENEFIT
  CLUB_CANCEL
}

enum ClubAsaasEnvironment {
  SANDBOX
  PRODUCTION
}

enum ClubMercadoPagoEnvironment {
  SANDBOX
  PRODUCTION
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}


enum TenantSubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

model Product {
  id            String                   @id @default(cuid())
  tenantId      String
  name          String
  description   String?
  price         Int                      @default(0) // preço em centavos
  imageUrl      String?
  stockQuantity Int                      @default(0)
  active        Boolean                  @default(true)
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt
  tenant        Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reservations  ProductReservationItem[]

  @@index([tenantId, active])
}

model ProductReservation {
  id        String                   @id @default(cuid())
  tenantId  String
  clientId  String
  status    ProductReservationStatus @default(PENDING)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt
  tenant    Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client    Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items     ProductReservationItem[]

  @@index([tenantId, status])
  @@index([clientId, status])
}

model ProductReservationItem {
  id                 String             @id @default(cuid())
  reservationId      String
  productId          String
  quantity           Int
  priceAtReservation Int // preço em centavos no momento da reserva
  reservation        ProductReservation @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  product            Product            @relation(fields: [productId], references: [id])

  @@index([reservationId])
  @@index([productId])
}

enum ProductReservationStatus {
  PENDING
  CONFIRMED
  CANCELED
  PICKED_UP
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Review {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String
  appointmentId String   @unique
  phoneE164     String
  clientName    String
  rating        Int      // 1-5
  comment       String?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([tenantId, phoneE164])
}

model GalleryPhoto {
  id        String   @id @default(cuid())
  tenantId  String
  imageUrl  String
  publicId  String   // Cloudinary public_id for deletion
  caption   String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sortOrder])
}

