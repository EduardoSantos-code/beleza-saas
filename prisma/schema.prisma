datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum WhatsAppInboundMessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  CONTACTS
  INTERACTIVE
  BUTTON
  ORDER
  REACTION
  UNKNOWN
}

enum TenantSubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}

model Tenant {
  id            String                    @id @default(cuid())
  name          String
  slug          String                    @unique
  timezone      String                    @default("America/Sao_Paulo")
  createdAt     DateTime                  @default(now())
  logoUrl       String?
  heroImageUrl  String?
  primaryColor  String?                   @default("#7c3aed")
  publicDescription String?
  publicPhone   String?
  address       String?
  instagram     String?

  subscriptionStatus            TenantSubscriptionStatus @default(NONE)
  trialEndsAt                   DateTime?
  stripeCustomerId              String?
  stripeSubscriptionId          String?
  stripePriceId                 String?
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionCancelAtPeriodEnd Boolean                  @default(false)

  memberships      Membership[]
  professionals    Professional[]
  services         Service[]
  clients          Client[]
  appointments     Appointment[]
  whatsappConfig   WhatsappConfig?
  businessHours    TenantBusinessHour[]
  blocks           ScheduleBlock[]
  inboundMessages  WhatsAppInboundMessage[]
  outboundMessages WhatsAppOutboundMessage[]
  minAdvanceHours  Int                       @default(2)
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  memberships  Membership[]
}

model Membership {
  id       String         @id @default(cuid())
  userId   String
  tenantId String
  role     MembershipRole @default(STAFF)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Professional {
  id            String                     @id @default(cuid())
  name          String
  phoneE164     String?                    
  commissionRate Int           @default(50)
  active        Boolean                    @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenantId      String
  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments  Appointment[]
  businessHours ProfessionalBusinessHour[]
  blocks        ScheduleBlock[]

  @@index([tenantId, active])
}

model Service {
  id           String        @id @default(cuid())
  tenantId     String
  name         String
  durationMin  Int
  price  Int                 @default(0)
  active       Boolean       @default(true)
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments Appointment[]

  @@index([tenantId, active])
}

model Client {
  id               String                    @id @default(cuid())
  tenantId         String
  name             String
  phoneE164        String
  email            String?
  createdAt        DateTime                  @default(now())
  tenant           Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments     Appointment[]
  inboundMessages  WhatsAppInboundMessage[]
  outboundMessages WhatsAppOutboundMessage[]

  @@unique([tenantId, phoneE164])
  @@index([tenantId])
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  professionalId String
  serviceId      String
  clientId       String
  
  timeZone       String            @default("America/Sao_Paulo")
  businessDate   String            
  startMinutes   Int               
  endMinutes     Int               

  startAt        DateTime
  endAt          DateTime
  status         AppointmentStatus @default(PENDING)
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Restrict)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  client       Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  reminder     Reminder?
  reminderSent Boolean      @default(false)

  @@index([tenantId, professionalId, startAt])
  @@index([tenantId, status])
  @@index([tenantId, businessDate])
}

model Reminder {
  id            String         @id @default(cuid())
  appointmentId String         @unique
  sendAt        DateTime
  status        ReminderStatus @default(PENDING)
  attempts      Int            @default(0)
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  appointment Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status, sendAt])
}

model WhatsappConfig {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  phoneNumberId String
  accessToken   String
  verifyToken   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantBusinessHour {
  id            String   @id @default(cuid())
  tenantId      String
  weekday       Weekday
  isOpen        Boolean  @default(false)
  startMin      Int?
  endMin        Int?
  breakStartMin Int?
  breakEndMin   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, weekday])
  @@index([tenantId, weekday])
}

model ProfessionalBusinessHour {
  id             String       @id @default(cuid())
  professionalId String
  weekday        Weekday
  isOpen         Boolean      @default(false)
  startMin       Int?
  endMin         Int?
  breakStartMin  Int?
  breakEndMin    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, weekday])
  @@index([professionalId, weekday])
}

model ScheduleBlock {
  id             String        @id @default(cuid())
  tenantId       String
  professionalId String?
  title          String
  startAt        DateTime
  endAt          DateTime
  allDay         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  professional   Professional? @relation(fields: [professionalId], references: [id], onDelete: SetNull)

  @@index([tenantId, startAt])
  @@index([professionalId, startAt])
}

model WhatsAppInboundMessage {
  id            String                     @id @default(cuid())
  tenantId      String
  clientId      String?
  waMessageId   String                     @unique
  phoneNumberId String
  fromPhoneE164 String
  fromName      String?
  type          WhatsAppInboundMessageType @default(UNKNOWN)
  textBody      String?
  rawJson       Json
  createdAt     DateTime                   @default(now())
  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client?                    @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([clientId, createdAt])
  @@index([fromPhoneE164, createdAt])
}

model WhatsAppOutboundMessage {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String?
  waMessageId   String?  @unique
  phoneNumberId String
  toPhoneE164   String
  textBody      String
  rawJson       Json?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([clientId, createdAt])
  @@index([toPhoneE164, createdAt])
}