generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Tenant {
  id                            String                    @id @default(cuid())
  name                          String
  slug                          String                    @unique
  timezone                      String                    @default("America/Sao_Paulo")
  createdAt                     DateTime                  @default(now())
  address                       String?
  heroImageUrl                  String?
  instagram                     String?
  logoUrl                       String?
  primaryColor                  String?                   @default("#7c3aed")
  publicDescription             String?
  publicPhone                   String?
  cpfCnpj                       String?
  asaasCustomerId               String?                   @unique
  asaasSubscriptionId           String?                   @unique
  planStatus                    String                    @default("TRIAL") // TRIAL, ACTIVE, OVERDUE
  subscriptionCancelAtPeriodEnd Boolean                   @default(false)
  subscriptionCurrentPeriodEnd  DateTime?
  subscriptionStatus            TenantSubscriptionStatus  @default(NONE)
  trialEndsAt                   DateTime?
  minAdvanceHours               Int                       @default(2)
  googleMapsLink                String?
  clubEnabled                   Boolean                   @default(false)
  clubPaymentProvider           ClubPaymentProvider?
  clubPlans                     ClubPlan[]
  clubSubscriptions             ClubSubscription[]
  appointments                  Appointment[]
  clients                       Client[]
  memberships                   Membership[]
  professionals                 Professional[]
  blocks                        ScheduleBlock[]
  services                      Service[]
  businessHours                 TenantBusinessHour[]
  inboundMessages               WhatsAppInboundMessage[]
  outboundMessages              WhatsAppOutboundMessage[]
  clientPhoneVerifications      ClientPhoneVerification[]
  whatsappConfig                WhatsappConfig?
}

model User {
  id           String       @id @default(cuid())
  name         String
  email        String       @unique
  passwordHash String
  createdAt    DateTime     @default(now())
  role         String       @default("USER")
  memberships  Membership[]
}

model Membership {
  id       String         @id @default(cuid())
  userId   String
  tenantId String
  role     MembershipRole @default(STAFF)
  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
}

model Professional {
  id             String                     @id @default(cuid())
  tenantId       String
  name           String
  active         Boolean                    @default(true)
  commissionRate Int                        @default(50)
  createdAt      DateTime                   @default(now())
  phoneE164      String?
  updatedAt      DateTime                   @updatedAt
  appointments   Appointment[]
  tenant         Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessHours  ProfessionalBusinessHour[]
  blocks         ScheduleBlock[]

  @@index([tenantId, active])
}

model Service {
  id           String        @id @default(cuid())
  tenantId     String
  name         String
  durationMin  Int
  active       Boolean       @default(true)
  price        Int           @default(0)
  appointments Appointment[]
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, active])
}

model Client {
  id                String                    @id @default(cuid())
  tenantId          String
  name              String
  phoneE164         String
  email             String?
  createdAt         DateTime                  @default(now())
  appointments      Appointment[]
  clubSubscriptions ClubSubscription[]
  tenant            Tenant                    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inboundMessages   WhatsAppInboundMessage[]
  outboundMessages  WhatsAppOutboundMessage[]

  @@unique([tenantId, phoneE164])
  @@index([tenantId])
}

model Appointment {
  id                 String             @id @default(cuid())
  tenantId           String
  professionalId     String
  serviceId          String
  clientId           String
  startAt            DateTime
  endAt              DateTime
  status             AppointmentStatus  @default(PENDING)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  businessDate       String
  endMinutes         Int
  startMinutes       Int
  timeZone           String             @default("America/Sao_Paulo")
  reminderSent       Boolean            @default(false)
  clubSubscriptionId String?
  clubPlanName       String?
  clubOriginalPrice  Int?
  clubDiscountAmount Int?
  clubFinalPrice     Int?
  client             Client             @relation(fields: [clientId], references: [id])
  professional       Professional       @relation(fields: [professionalId], references: [id])
  service            Service            @relation(fields: [serviceId], references: [id])
  tenant             Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  reminder           Reminder?
  clubSubscription   ClubSubscription?  @relation(fields: [clubSubscriptionId], references: [id])
  clubBenefitUsages  ClubBenefitUsage[]

  @@index([tenantId, professionalId, startAt])
  @@index([tenantId, status])
  @@index([tenantId, businessDate])
}

model Reminder {
  id            String         @id @default(cuid())
  appointmentId String         @unique
  sendAt        DateTime
  status        ReminderStatus @default(PENDING)
  attempts      Int            @default(0)
  error         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([status, sendAt])
}

model WhatsappConfig {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  phoneNumberId String
  accessToken   String
  verifyToken   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantBusinessHour {
  id            String   @id @default(cuid())
  tenantId      String
  weekday       Weekday
  isOpen        Boolean  @default(false)
  startMin      Int?
  endMin        Int?
  breakStartMin Int?
  breakEndMin   Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, weekday])
  @@index([tenantId, weekday])
}

model ProfessionalBusinessHour {
  id             String       @id @default(cuid())
  professionalId String
  weekday        Weekday
  isOpen         Boolean      @default(false)
  startMin       Int?
  endMin         Int?
  breakStartMin  Int?
  breakEndMin    Int?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  professional   Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, weekday])
  @@index([professionalId, weekday])
}

model ScheduleBlock {
  id             String        @id @default(cuid())
  tenantId       String
  professionalId String?
  title          String
  startAt        DateTime
  endAt          DateTime
  allDay         Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  professional   Professional? @relation(fields: [professionalId], references: [id])
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, startAt])
  @@index([professionalId, startAt])
}

model WhatsAppInboundMessage {
  id            String                     @id @default(cuid())
  tenantId      String
  clientId      String?
  waMessageId   String                     @unique
  phoneNumberId String
  fromPhoneE164 String
  fromName      String?
  type          WhatsAppInboundMessageType @default(UNKNOWN)
  textBody      String?
  rawJson       Json
  createdAt     DateTime                   @default(now())
  client        Client?                    @relation(fields: [clientId], references: [id])
  tenant        Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([clientId, createdAt])
  @@index([fromPhoneE164, createdAt])
}

model WhatsAppOutboundMessage {
  id            String   @id @default(cuid())
  tenantId      String
  clientId      String?
  waMessageId   String?  @unique
  phoneNumberId String
  toPhoneE164   String
  textBody      String
  rawJson       Json?
  createdAt     DateTime @default(now())
  client        Client?  @relation(fields: [clientId], references: [id])
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([clientId, createdAt])
  @@index([toPhoneE164, createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("INFO")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model ClubPlan {
  id               String             @id @default(cuid())
  tenantId         String
  name             String
  description      String?
  terms            String?
  priceInCents     Int
  billingCycle     ClubBillingCycle   @default(MONTHLY)
  discountPercent  Int?
  includedServices Json?
  isActive         Boolean            @default(true)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscriptions    ClubSubscription[]

  @@index([tenantId])
  @@index([tenantId, isActive])
}

model ClubSubscription {
  id                     String                 @id @default(cuid())
  tenantId               String
  clientId               String
  planId                 String
  provider               ClubPaymentProvider
  status                 ClubSubscriptionStatus @default(PENDING)
  providerCustomerId     String?
  providerSubscriptionId String?
  providerPaymentId      String?
  providerCheckoutUrl    String?
  currentPeriodStart     DateTime?
  currentPeriodEnd       DateTime?
  canceledAt             DateTime?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  tenant                 Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client                 Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  plan                   ClubPlan               @relation(fields: [planId], references: [id])
  usages                 ClubBenefitUsage[]
  appointments           Appointment[]

  @@index([tenantId, clientId])
  @@index([tenantId, status])
  @@index([provider, providerSubscriptionId])
}

model ClubBenefitUsage {
  id             String           @id @default(cuid())
  tenantId       String
  subscriptionId String
  appointmentId  String?
  benefitCode    String
  periodKey      String
  usedAt         DateTime         @default(now())
  subscription   ClubSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  appointment    Appointment?     @relation(fields: [appointmentId], references: [id])

  @@unique([subscriptionId, benefitCode, periodKey])
  @@index([tenantId])
  @@index([subscriptionId])
  @@index([appointmentId])
}

model ClientPhoneVerification {
  id        String                         @id @default(cuid())
  tenantId  String
  phoneE164 String
  codeHash  String
  purpose   ClientPhoneVerificationPurpose
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime                       @default(now())
  tenant    Tenant                         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, phoneE164])
  @@index([tenantId, phoneE164, purpose])
}

enum ClubPaymentProvider {
  ASAAS
  MERCADO_PAGO
}

enum ClubBillingCycle {
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

enum ClubSubscriptionStatus {
  PENDING
  ACTIVE
  OVERDUE
  CANCELED
  EXPIRED
}

enum MembershipRole {
  OWNER
  MANAGER
  STAFF
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELED
  COMPLETED
}

enum ReminderStatus {
  PENDING
  SENT
  FAILED
}

enum ClientPhoneVerificationPurpose {
  CLUB_SUBSCRIBE
  CLUB_PORTAL
  CLUB_USE_BENEFIT
  CLUB_CANCEL
}

enum Weekday {
  SUNDAY
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
}

enum WhatsAppInboundMessageType {
  TEXT
  IMAGE
  AUDIO
  VIDEO
  DOCUMENT
  STICKER
  LOCATION
  CONTACTS
  INTERACTIVE
  BUTTON
  ORDER
  REACTION
  UNKNOWN
}

enum TenantSubscriptionStatus {
  NONE
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  UNPAID
  PAUSED
}
